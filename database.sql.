CREATE DATABASE IF NOT EXISTS nexus_academy;
USE nexus_academy;

CREATE TABLE alumnos (
    id INT PRIMARY KEY,
    nombre VARCHAR(50) NOT NULL,
    apellido VARCHAR(50) NOT NULL,
    celular VARCHAR(20),
    nota_final DECIMAL(4, 2),
    estado VARCHAR(20) GENERATED ALWAYS AS (CASE WHEN nota_final < 4 THEN 'Riesgo' ELSE 'Regular' END)
);

